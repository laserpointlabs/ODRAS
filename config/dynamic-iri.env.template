# ODRAS Dynamic IRI Configuration Template
# Copy this to .env in the root directory and customize for your installation

# =============================================================================
# CUSTOMER CONFIGURATION (Multi-Tenant Ready)
# =============================================================================

# Customer's base domain - this is where ODRAS is deployed
INSTALLATION_BASE_URI=https://company.com

# Optional prefix (can be empty for clean URLs)
# Examples: "odras", "ontologies", "" (empty for no prefix)
INSTALLATION_PREFIX=

# Resulting Dynamic IRIs (based on admin-created namespaces):
# Clean URLs (no prefix): https://company.com/gov/dod/usn/project/23RT-56TW/45GH-34TG#B459-34TY
# With prefix: https://company.com/odras/gov/dod/usn/project/23RT-56TW/45GH-34TG#B459-34TY

# =============================================================================
# EXAMPLE CUSTOMER CONFIGURATIONS
# =============================================================================

# Navy Command Installation:
# INSTALLATION_BASE_URI=https://xma-adt.usn.mil
# INSTALLATION_PREFIX=usn
# Results in: https://xma-adt.usn.mil/usn/gov/dod/usn/project/23RT-56TW/...

# Air Force Installation:
# INSTALLATION_BASE_URI=https://afit.usaf.mil
# INSTALLATION_PREFIX=usaf
# Results in: https://afit.usaf.mil/usaf/gov/dod/usaf/domain/67GH-89TY/...

# Boeing Installation:
# INSTALLATION_BASE_URI=https://ontologies.boeing.com
# INSTALLATION_PREFIX=
# Results in: https://ontologies.boeing.com/industry/boeing/core/89JK-12LM/...

# Development Environment:
# INSTALLATION_BASE_URI=http://localhost:8000
# INSTALLATION_PREFIX=
# Results in: http://localhost:8000/dev/testing/core/45QR-67ST/...

# =============================================================================
# W3ID.org PERMANENT IDENTIFIERS (RECOMMENDED FOR PRODUCTION)
# =============================================================================

# For stable, permanent identifiers, register with w3id.org:
# INSTALLATION_BASE_URI=https://w3id.org/your-organization
# INSTALLATION_PREFIX=
# Results in: https://w3id.org/your-organization/gov/dod/usn/project/23RT-56TW/...

# W3ID.org redirects to your actual deployment, providing permanent identifiers
# that never change even if you move servers or domains.

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=odras
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=odras-files
MINIO_SECURE=false

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# SERVICE URLS
# =============================================================================
QDRANT_URL=http://localhost:6333
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword
FUSEKI_URL=http://localhost:3030/odras
CAMUNDA_BASE_URL=http://localhost:8080
REDIS_URL=redis://localhost:6379

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
API_BASE_URL=http://localhost:8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# =============================================================================
# IRI GENERATION NOTES
# =============================================================================

# ODRAS uses a completely dynamic IRI system:
# 1. Admins create namespaces in the UI by selecting prefixes + type
#    Example: ["gov", "dod", "usn"] + "project" = "gov/dod/usn/project"
# 2. All resources use 8-digit stable IDs (e.g., "23RT-56TW")
# 3. IRIs are generated: {base_uri}/{prefix}/{namespace_path}/{resource_ids...}#{entity_id}
# 4. NO hardcoded resource types - everything comes from namespace configuration
# 5. Multi-tenant ready - each customer configures their own base URI

# Example namespace creation in admin UI:
# Prefixes: ["gov", "dod", "usn"]
# Type: "project"
# Result: namespace_path = "gov/dod/usn/project"
#
# IRIs generated:
# Project: https://base.mil/gov/dod/usn/project/23RT-56TW/
# Ontology: https://base.mil/gov/dod/usn/project/23RT-56TW/45GH-34TG/
# Entity: https://base.mil/gov/dod/usn/project/23RT-56TW/45GH-34TG#B459-34TY
